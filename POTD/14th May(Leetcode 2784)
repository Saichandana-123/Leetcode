class Solution {
public:
    bool isGood(vector<int>& nums) {
        sort(nums.begin(), nums.end());
        int n = nums.size();
        for (int i = 0; i+1< n; i++) {
            if (nums[i] != i + 1) {
                return false;
            }
        }
        if(nums[n-1]==n-1) return true;
        
        return false;
    }
};
//Time Complexity : O(nlogn)
//space complexity : O(1)
